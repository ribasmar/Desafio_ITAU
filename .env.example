# ──────────────────────────────────────────────────────────────
# LLM Client configuration — Copom Quant AI
# Copy this file to .env and edit values as needed.
# ──────────────────────────────────────────────────────────────

# Provider: "local" (llama.cpp) | "ollama" | "openrouter"
LLM_PROVIDER=ollama

# ── Ollama ───────────────────────────────────────────────────
# Default model served by your local Ollama instance.
OLLAMA_MODEL=qwen2.5:7b
# Ollama server address (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# ── Local (llama-server) ────────────────────────────────────
# URL of a running llama-server instance (OpenAI-compatible endpoint).
# Start the server:
#   LD_LIBRARY_PATH=./llama.cpp/bin ./llama.cpp/bin/llama-server \
#       -m ./Qwen2.5-7B-Instruct-Q8_0.gguf --host 127.0.0.1 --port 8080
LLAMA_SERVER_URL=http://127.0.0.1:8080

# ── OpenRouter ───────────────────────────────────────────────
# API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model identifier — use a slug exata da OpenRouter.
# Ex: https://openrouter.ai/qwen/qwen-2.5-7b-instruct → qwen/qwen-2.5-7b-instruct
LLM_MODEL_OPENROUTER=meta-llama/llama-3.1-8b-instruct
#provider 
OPENROUTER_PROVIDER=groq

# ── Prompt ───────────────────────────────────────────────────
# Caminho do template de prompt. Se vazio, usa prompts/copom_v1.md.
PROMPT_PATH=./prompts/copom_v1.md

# ── Global ───────────────────────────────────────────────────
# Random seed for deterministic / reproducible output.
SEED=42
# Sampling temperature. 0.0 = greedy (deterministic).
TEMPERATURE=0.0
